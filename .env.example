# Copy this file to .env and fill in your real values

# Get test keys free at https://dashboard.razorpay.com/app/keys (Test Mode toggle, top right)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret_here

# Port the server runs on
PORT=3000

# Public URL of this server — used to build the QR code the customer scans.
# Leave this as-is (localhost) and the server will AUTO-DETECT the correct
# public URL from each request — so a new ngrok/localtunnel/cloudflared URL
# just works without editing this file every time you restart the tunnel.
# Only set this to a real https:// URL if you have a fixed domain and want
# to force it (overrides auto-detection).
BASE_URL=http://localhost:3000
